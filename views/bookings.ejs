<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Admin Dashboard - Bookings</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/index.css">
</head>
<body>
  <h1>Admin Dashboard - Bookings</h1>

  <a href="/admin/export" class="download-btn">⬇️ Download CSV</a>

  <% if (bookings.length > 0) { %>
    <table>
      <thead>
        <tr>
          <th>ID</th>
          <th>Name</th>
          <th>Email</th>
          <th>Phone</th>
          <th>Display Type</th>
          <th>Message</th>
          <th>Created At</th>
        </tr>
      </thead>
      <tbody>
        <% bookings.forEach(b => { %>
          <tr>
            <td><%= b.id %></td>
            <td><%= b.name %></td>
            <td><%= b.email %></td>
            <td><%= b.phone %></td>
            <td><%= b.display_type == 1 ? 'Indoor' : 'Outdoor' %></td>
            <td><%= b.message %></td>
            <td><%= b.created_at.toLocaleString() %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } else { %>
    <p>No bookings found.</p>
  <% } %>
</body>
</html>
